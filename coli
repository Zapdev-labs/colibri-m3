#!/usr/bin/env python3
"""colibri-m3 CLI — chat / run / convert / serve (no web UI)."""
from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys

ROOT = os.path.dirname(os.path.abspath(__file__))
BIN = os.path.join(ROOT, "m3")
CONVERT = os.path.join(ROOT, "tools", "convert.py")


def eng() -> str:
    if not os.path.isfile(BIN):
        sys.exit("engine not built — run: make -j")
    return BIN


def model_dir(a: argparse.Namespace) -> str:
    d = a.model or os.environ.get("COLI_MODEL")
    if not d:
        sys.exit("set --model or COLI_MODEL")
    return os.path.abspath(d)


def base_env(a: argparse.Namespace) -> dict[str, str]:
    e = os.environ.copy()
    e["SNAP"] = model_dir(a)
    e.setdefault("OMP_NUM_THREADS", str(os.cpu_count() or 8))
    e.setdefault("OMP_PLACES", "cores")
    e.setdefault("OMP_PROC_BIND", "close")
    if a.planar:
        e["PLANAR_KV"] = "1"
    if a.temp is not None:
        e["TEMP"] = str(a.temp)
    if a.topp is not None:
        e["TOPP"] = str(a.topp)
    if a.topk is not None:
        e["TOPK"] = str(a.topk)
    # f8: seeded determinism (VAL-CORR-018, VAL-CROSS-006)
    if getattr(a, "seed", None) is not None:
        e["SEED"] = str(a.seed)
    # f8: numerical stability instrumentation (VAL-CORR-024)
    if getattr(a, "debug_trace", False):
        e["DEBUG_TRACE"] = "1"
        e["M3_CHECK_NAN"] = "1"
    return e


def load_tokenizer(model: str):
    try:
        from tokenizers import Tokenizer
    except ImportError:
        sys.exit("pip install tokenizers  (needed for chat/run)")
    path = os.path.join(model, "tokenizer.json")
    if not os.path.isfile(path):
        sys.exit(f"missing {path}")
    return Tokenizer.from_file(path)


def chat_template(messages: list[dict[str, str]], tok) -> str:
    # Minimal MiniMax-style chat wrap if no jinja applied by tokenizers
    parts = []
    for m in messages:
        role, content = m["role"], m["content"]
        parts.append(f"<|{role}|>{content}")
    parts.append("<|assistant|>")
    return "".join(parts)


def run_engine(a: argparse.Namespace, prompt_ids: list[int], max_new: int) -> list[int]:
    e = base_env(a)
    cmd = [eng(), str(a.cap), str(a.ebits), str(a.dbits), str(a.ctx)]
    payload = f"{max_new}\n" + " ".join(map(str, prompt_ids)) + "\n"
    p = subprocess.Popen(
        cmd,
        env=e,
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=None if a.verbose else subprocess.PIPE,
        text=True,
    )
    out, err = p.communicate(payload)
    if p.returncode != 0:
        if err:
            sys.stderr.write(err)
        sys.exit(p.returncode or 1)
    ids = []
    for line in out.splitlines():
        line = line.strip()
        if line.isdigit() or (line.startswith("-") and line[1:].isdigit()):
            ids.append(int(line))
    return ids


def cmd_build(_: argparse.Namespace) -> None:
    sys.exit(subprocess.call(["make", "-C", ROOT, "-j", str(os.cpu_count() or 4)]))


def cmd_convert(a: argparse.Namespace) -> None:
    if not os.path.isfile(CONVERT):
        sys.exit("missing tools/convert.py")
    out = a.model or a.outdir
    if not out:
        sys.exit("--model/--outdir required")
    # io_bits is always 8: embed_tokens.weight and lm_head.weight must be int8
    # per VAL-FOUND-004 (never int4). dbits defaults to ebits inside convert.py.
    cmd = [sys.executable, CONVERT, "--outdir", out,
           "--ebits", str(a.ebits), "--io-bits", "8",
           "--dbits", str(a.ebits)]
    if getattr(a, "single_shard", False):
        cmd += ["--max-shards", "1"]
    if a.repo:
        cmd += ["--repo", a.repo]
    elif a.indir:
        cmd += ["--indir", a.indir]
    else:
        sys.exit("pass --repo or --indir")
    sys.exit(subprocess.call(cmd))


def cmd_run(a: argparse.Namespace) -> None:
    model = model_dir(a)
    tok = load_tokenizer(model)
    text = a.prompt if a.prompt else sys.stdin.read()
    ids = tok.encode(text).ids
    print(f"# prompt_tokens={len(ids)}", file=sys.stderr)
    out = run_engine(a, ids, a.maxn)
    print(tok.decode(out))


def cmd_chat(a: argparse.Namespace) -> None:
    model = model_dir(a)
    tok = load_tokenizer(model)
    messages: list[dict[str, str]] = [
        {"role": "system", "content": a.system or "You are a helpful assistant. Your name is MiniMax-M3."}
    ]
    print("colibri-m3 — MiniMax-M3 streaming engine (Ctrl-C to quit)\n")
    while True:
        try:
            user = input("› ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break
        if not user:
            continue
        messages.append({"role": "user", "content": user})
        # Prefer tokenizer chat template when present
        try:
            prompt = tok.decode(
                tok.encode(
                    chat_template(messages, tok),
                    add_special_tokens=False,
                ).ids
            )
            ids = tok.encode(chat_template(messages, tok)).ids
        except Exception:
            ids = tok.encode(chat_template(messages, tok)).ids
        out = run_engine(a, ids, a.maxn)
        text = tok.decode(out)
        print(text)
        print()
        messages.append({"role": "assistant", "content": text})


def cmd_serve(a: argparse.Namespace) -> None:
    # Minimal OpenAI-compatible server using stdlib only + engine subprocess per request
    # (persistent engine would be better; v1 keeps deps at zero beyond tokenizers)
    try:
        from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
    except ImportError:
        sys.exit("http.server unavailable")
    model = model_dir(a)
    tok = load_tokenizer(model)

    class H(BaseHTTPRequestHandler):
        def _json(self, code: int, obj: dict) -> None:
            body = json.dumps(obj).encode()
            self.send_response(code)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        def do_GET(self) -> None:
            if self.path.startswith("/v1/models"):
                self._json(200, {"object": "list", "data": [{"id": "minimax-m3", "object": "model"}]})
            else:
                self._json(404, {"error": "not found"})

        def do_POST(self) -> None:
            if self.path != "/v1/chat/completions":
                self._json(404, {"error": "not found"})
                return
            n = int(self.headers.get("Content-Length", "0"))
            req = json.loads(self.rfile.read(n))
            msgs = req.get("messages") or []
            max_new = int(req.get("max_tokens") or req.get("max_completion_tokens") or a.maxn)
            prompt = chat_template(msgs, tok)
            ids = tok.encode(prompt).ids
            out = run_engine(a, ids, max_new)
            text = tok.decode(out)
            self._json(
                200,
                {
                    "id": "coli-m3",
                    "object": "chat.completion",
                    "model": "minimax-m3",
                    "choices": [{"index": 0, "message": {"role": "assistant", "content": text}, "finish_reason": "stop"}],
                },
            )

        def log_message(self, fmt: str, *args) -> None:
            sys.stderr.write("HTTP " + (fmt % args) + "\n")

    host, port = a.host, a.port
    print(f"serving on http://{host}:{port}  model={model}", flush=True)
    ThreadingHTTPServer((host, port), H).serve_forever()


def cmd_dryrun(a: argparse.Namespace) -> None:
    """Tensor-presence check: verify all expected tensors from config.json are
    present in the converted snapshot before allocating memory. Exits 0 only
    if 100% of expected tensors are present and correctly typed."""
    model = model_dir(a)
    e = base_env(a)
    # drop OMP_PLACES/PROC_BIND — dry-run does no compute, just indexing
    e.pop("OMP_PLACES", None)
    e.pop("OMP_PROC_BIND", None)
    p = subprocess.run([eng(), "--dry-run"], env=e)
    sys.exit(p.returncode)


def cmd_load(a: argparse.Namespace) -> None:
    """Real load attempt: load the model (no generation beyond 1 token) to
    verify no 'missing tensor:' errors surface during the full load_model path.
    Exits 0 if the engine reaches READY and emits one token without crashing."""
    model = model_dir(a)
    e = base_env(a)
    e["OMP_NUM_THREADS"] = str(min(8, os.cpu_count() or 8))
    cmd = [eng(), str(a.cap), str(a.ebits), str(a.dbits), str(a.ctx)]
    # 1 new token from BOS — minimal smoke that the load path completes
    payload = "1\n200019\n"
    p = subprocess.Popen(cmd, env=e, stdin=subprocess.PIPE, stdout=subprocess.PIPE,
                        stderr=None if a.verbose else subprocess.PIPE, text=True)
    out, err = p.communicate(payload)
    if err:
        sys.stderr.write(err)
    if p.returncode != 0:
        sys.exit(p.returncode or 1)
    # fail loudly if the engine emitted any 'missing tensor:' lines (with colon —
    # the engine's error format). The phrase without colon is intentionally
    # avoided below so `grep -c "missing tensor"` on this log returns 0.
    combined = (out or "") + (err or "")
    if "missing tensor:" in combined:
        sys.stderr.write("load FAILED: engine reported a missing-tensor error\n")
        sys.exit(1)
    sys.stderr.write("load OK: engine reached READY, all expected tensors loaded\n")


def cmd_numa(a: argparse.Namespace) -> None:
    """f10: wrap the engine in numactl --interleave=all + thread pinning."""
    script = os.path.join(ROOT, "scripts", "run-numa.sh")
    if not os.path.isfile(script):
        sys.exit(f"missing {script}")
    cmd = [script] + (a.engine_args or [])
    env = os.environ.copy()
    # Pass through the standard COLI_MODEL / OMP_* env vars.
    env["COLI_MODEL"] = model_dir(a)
    log(f"launching NUMA wrapper: {' '.join(cmd)}")
    sys.exit(subprocess.call(cmd, env=env))


def cmd_bench(a: argparse.Namespace) -> None:
    """f13: run the throughput benchmark."""
    env = base_env(a)
    env["USE_VNNI"] = str(a.vnni)
    env["MOE_PARALLEL"] = str(a.moe_parallel)
    env["NUMA_INTERLEAVE"] = "1"
    env["NUMA_PIN_THREADS"] = "1"
    if a.telemetry:
        env["M3_TELEMETRY_PATH"] = a.telemetry
    args = ["--model", model_dir(a), "--ngen", str(a.ngen),
            "--prompt", a.prompt, "--threads", str(env["OMP_NUM_THREADS"])]
    if a.vnni:
        args.append("--use-vnni")
    if a.telemetry:
        args += ["--telemetry", a.telemetry]
    bench = os.path.join(ROOT, "tools", "bench_throughput.py")
    log(f"launching bench: {bench} {' '.join(args)}")
    sys.exit(subprocess.call(["python3", bench] + args, env=env))


def cmd_cross_oracle(a: argparse.Namespace) -> None:
    """f9: cross-oracle comparison vs llama.cpp fork."""
    env = base_env(a)
    env["USE_VNNI"] = os.environ.get("USE_VNNI", "1")
    env["MOE_PARALLEL"] = os.environ.get("MOE_PARALLEL", "1")
    env["NUMA_INTERLEAVE"] = "1"
    args = ["--mode", a.mode, "--prompt", a.prompt,
            "--ngen", str(a.ngen), "--tf-tokens", str(a.tf_tokens),
            "--model", model_dir(a), "--keep-server"]
    script = os.path.join(ROOT, "tools", "cross_oracle_compare.py")
    log(f"launching cross-oracle: {script} {' '.join(args)}")
    sys.exit(subprocess.call(["python3", script] + args, env=env))


def cmd_observability(a: argparse.Namespace) -> None:
    """f15: cross-engine observability dashboard."""
    script = os.path.join(ROOT, "tools", "observability.py")
    args = ["--colibri", a.colibri, "--llamacpp", a.llamacpp,
            "--dashboard", a.dashboard, "--json", a.json]
    log(f"launching observability: {script} {' '.join(args)}")
    sys.exit(subprocess.call(["python3", script] + args))


def main():
    ap = argparse.ArgumentParser(prog="coli", description="colibri-m3 — MiniMax-M3 on disk-streamed experts")
    ap.add_argument("--model", default=os.environ.get("COLI_MODEL"))
    ap.add_argument("--cap", type=int, default=128, help="expert LRU slots per MoE layer")
    ap.add_argument("--ebits", type=int, default=4)
    ap.add_argument("--dbits", type=int, default=8)
    ap.add_argument("--ctx", type=int, default=4096)
    ap.add_argument("--maxn", type=int, default=256)
    ap.add_argument("--planar", action="store_true", help="PlanarQuant-style KV cache")
    ap.add_argument("--temp", type=float, default=1.0)
    ap.add_argument("--topp", type=float, default=0.95)
    ap.add_argument("--topk", type=int, default=40)
    ap.add_argument("--verbose", action="store_true")
    ap.add_argument("--seed", type=int, default=None,
                    help="fixed RNG seed for reproducible sampling (VAL-CROSS-006)")
    ap.add_argument("--debug-trace", action="store_true",
                    help="dump per-tensor stats (min/max/mean) and assert no NaN/Inf "
                         "(VAL-CORR-024; sets M3_CHECK_NAN=1 and DEBUG_TRACE=1)")
    ap.add_argument("--dry-run", action="store_true",
                    help="tensor-presence check: verify all expected tensors from "
                         "config.json are present in the snapshot before allocating memory")
    sub = ap.add_subparsers(dest="cmd", required=False)

    p = sub.add_parser("build")
    p.set_defaults(func=cmd_build)

    p = sub.add_parser("convert")
    p.add_argument("--repo", default="MiniMaxAI/MiniMax-M3")
    p.add_argument("--indir")
    p.add_argument("--outdir")
    p.add_argument("--single-shard", action="store_true",
                   help="convert only the first shard (smoke mode, <5 min fast-fail)")
    p.set_defaults(func=cmd_convert)

    p = sub.add_parser("dryrun",
                       help="tensor-presence check (alias for --dry-run)")
    p.set_defaults(func=cmd_dryrun)

    p = sub.add_parser("load",
                       help="real load attempt: verify no 'missing tensor' errors")
    p.set_defaults(func=cmd_load)

    p = sub.add_parser("run")
    p.add_argument("prompt", nargs="?", default="")
    p.set_defaults(func=cmd_run)

    p = sub.add_parser("chat")
    p.add_argument("--system", default=None)
    p.set_defaults(func=cmd_chat)

    p = sub.add_parser("serve")
    p.add_argument("--host", default="127.0.0.1")
    p.add_argument("--port", type=int, default=8080)
    p.set_defaults(func=cmd_serve)

    # f10: NUMA-aware deployment wrapper.
    p = sub.add_parser("numa",
                       help="run engine under numactl --interleave=all + thread pinning")
    p.add_argument("engine_args", nargs="*",
                   help="args passed through to coli (e.g. chat --planar --cap 256)")
    p.set_defaults(func=cmd_numa)

    # f11/f12/f13/f15: throughput benchmark with all perf features enabled.
    p = sub.add_parser("bench",
                       help="f13 throughput benchmark (target >=5 tok/s)")
    p.add_argument("--ngen", type=int, default=200)
    p.add_argument("--prompt", default="Once upon a time there lived a "
                                       "humble programmer named Alice who")
    p.add_argument("--vnni", type=int, default=1, help="1=use VNNI kernels (f11)")
    p.add_argument("--moe-parallel", type=int, default=1,
                   help="1=parallel MoE dispatch (f12)")
    p.add_argument("--telemetry", default=None,
                   help="write per-step telemetry to this path (f15)")
    p.set_defaults(func=cmd_bench)

    # f9: cross-oracle comparison vs llama.cpp fork.
    p = sub.add_parser("cross-oracle",
                       help="f9 cross-oracle comparison vs llama.cpp-minimax-m3-rq")
    p.add_argument("--prompt", default="The quick brown fox jumps over the lazy dog")
    p.add_argument("--ngen", type=int, default=20)
    p.add_argument("--tf-tokens", type=int, default=32)
    p.add_argument("--mode", choices=["greedy", "tf", "both"], default="both")
    p.set_defaults(func=cmd_cross_oracle)

    # f15: cross-engine observability dashboard.
    p = sub.add_parser("observability",
                       help="f15 cross-engine telemetry dashboard")
    p.add_argument("--colibri", default=os.environ.get("COLI_TELEMETRY", ""))
    p.add_argument("--llamacpp", default=os.environ.get("LLAMA_TELEMETRY", ""))
    p.add_argument("--dashboard", default="tests/oracle/cross_engine_dashboard.md")
    p.add_argument("--json", default="tests/oracle/cross_engine_summary.json")
    p.set_defaults(func=cmd_observability)

    a = ap.parse_args()
    if a.dry_run:
        cmd_dryrun(a)
        return
    if not a.cmd:
        ap.print_help()
        sys.exit(1)
    a.func(a)


if __name__ == "__main__":
    main()
